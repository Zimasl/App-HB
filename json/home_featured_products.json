{
  "version": "1.1",
  "notes": [
    "sections содержит до 3 блоков на главной.",
    "enabled=false внутри конкретной секции скрывает только ее на главной.",
    "show_title=false скрывает название раздела.",
    "show_view_all_label=false скрывает ссылку Все.",
    "category_id управляет подборкой товаров.",
    "banner.image можно указывать абсолютным или относительным URL.",
    "positions.products_offset_y двигает карточки товара вверх или вниз относительно баннера.",
    "timer.enabled=false скрывает таймер.",
    "timer.end_at поддерживает ISO-дату, например 2026-12-31T23:59:59+03:00.",
    "banner.overlay управляет цветовым наложением поверх картинки баннера.",
    "text_styles управляет размерами, жирностью, цветом и выравниванием текста.",
    "positions управляет отступами и размещением текста в секции и на баннере.",
    "card_layout управляет внутренними отступами и расстояниями между текстами в карточке."
